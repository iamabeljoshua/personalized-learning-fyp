# Database (Docker internal — service name as host, internal port)
DB_HOST=postgres
DB_PORT=5432
DB_USER=tutor
DB_PASSWORD=pass
DB_NAME=agentic_tutor
POSTGRES_USER=tutor
POSTGRES_PASSWORD=pass
POSTGRES_DB=agentic_tutor

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AI Service
AI_SERVICE_URL=http://ai-service:8000
INTERNAL_API_KEY=dev-internal-api-key-change-in-production

# LLM (Ollama runs natively on host, Docker containers reach it via host.docker.internal)
OLLAMA_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2

# Video LLM (defaults to local Ollama, for better video quality, use a cloud model)
# To use Gemini: VIDEO_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  VIDEO_LLM_API_KEY=your-key  VIDEO_LLM_MODEL=gemini-2.5-flash
VIDEO_LLM_BASE_URL=http://host.docker.internal:11434/v1
VIDEO_LLM_API_KEY=ollama
VIDEO_LLM_MODEL=llama3.2

# Image generation (disabled by default, configure for inline images in lesson text)
# To use Google Imagen: IMAGE_PROVIDER=google  IMAGE_API_KEY=your-key  IMAGE_MODEL=imagen-3.0-generate-002
# To use OpenAI DALL-E: IMAGE_PROVIDER=openai  IMAGE_API_KEY=your-key  IMAGE_MODEL=dall-e-3
IMAGE_PROVIDER=
IMAGE_API_KEY=
IMAGE_MODEL=
IMAGE_BASE_URL=

# TTS (Chatterbox runs natively on host, Docker reaches via host.docker.internal)
TTS_URL=http://host.docker.internal:8004

# Manim
MANIM_CONTAINER_NAME=manim

# Storage
MEDIA_STORAGE_PATH=/media

