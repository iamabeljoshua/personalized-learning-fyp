# Root .env — used by docker-compose for postgres variable substitution
POSTGRES_USER=tutor
POSTGRES_PASSWORD=pass
POSTGRES_DB=agentic_tutor

# the LLM used to generate the manim code for the video rendering (defaults to local Ollama, use a cloud model for better performance)
VIDEO_LLM_BASE_URL=http://localhost:11434/v1
VIDEO_LLM_API_KEY=ollama
VIDEO_LLM_MODEL=llama3.2
