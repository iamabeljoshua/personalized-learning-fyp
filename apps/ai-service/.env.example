# Internal service auth
INTERNAL_API_KEY=dev-internal-api-key-change-in-production

# LLM (Ollama running locally)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Video LLM (defaults to local Ollama, for better video quality, use a cloud model)
# To use Gemini: VIDEO_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  VIDEO_LLM_API_KEY=your-key  VIDEO_LLM_MODEL=gemini-2.5-flash
VIDEO_LLM_BASE_URL=http://localhost:11434/v1
VIDEO_LLM_API_KEY=ollama
VIDEO_LLM_MODEL=llama3.2

# Image generation (disabled by default)
# To use Google Imagen: IMAGE_PROVIDER=google  IMAGE_API_KEY=your-key  IMAGE_MODEL=imagen-3.0-generate-002
# To use OpenAI DALL-E: IMAGE_PROVIDER=openai  IMAGE_API_KEY=your-key  IMAGE_MODEL=dall-e-3
IMAGE_PROVIDER=
IMAGE_API_KEY=
IMAGE_MODEL=
IMAGE_BASE_URL=

# TTS (Chatterbox running locally)
TTS_URL=http://localhost:8004
